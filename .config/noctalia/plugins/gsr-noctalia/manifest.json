{
  "id": "gsr-noctalia",
  "name": "GSR-Noctalia",
  "version": "1.0.0",
  "minNoctaliaVersion": "3.6.0",
  "author": "Brett (fork of Noctalia Team)",
  "license": "MIT",
  "description": "Forked gpu-screen-recorder plugin with multi-track audio, container format, audio bitrate, bitrate/framerate modes, encoder selection, and post-save script options",
  "tags": [
    "Bar",
    "Utility"
  ],
  "entryPoints": {
    "main": "Main.qml",
    "barWidget": "BarWidget.qml",
    "controlCenterWidget": "ControlCenterWidget.qml",
    "settings": "Settings.qml"
  },
  "dependencies": {
    "plugins": []
  },
  "metadata": {
    "defaultSettings": {
      "hideInactive": false,
      "iconColor": "none",
      "directory": "",
      "filenamePattern": "recording_yyyyMMdd_HHmmss",
      "frameRate": "60",
      "customFrameRate": "60",
      "frameRateMode": "vfr",
      "audioCodec": "opus",
      "audioBitrate": "",
      "videoCodec": "h264",
      "quality": "very_high",
      "bitrateMode": "auto",
      "colorRange": "limited",
      "showCursor": true,
      "copyToClipboard": false,
      "audioTracks": ["default_output"],
      "videoSource": "portal",
      "resolution": "original",
      "container": "mp4",
      "encoder": "gpu",
      "fallbackCpuEncoding": false,
      "keyframeInterval": "",
      "postSaveScript": "",
      "replayEnabled": false,
      "replayAlwaysOn": false,
      "replayDuration": "30",
      "customReplayDuration": "30",
      "replayStorage": "ram",
      "restartReplayOnSave": false,
      "dateFolders": false,
      "restorePortalSession": false
    }
  }
}
